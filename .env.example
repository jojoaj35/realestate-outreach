# Copy this to .env and fill in your keys.

# ── Scraping ────────────────────────────────────────────────────────────────
# ScrapingBee — optional fallback. The default scraper uses a real Chrome
# browser (Playwright) and needs no key. Sign up at https://www.scrapingbee.com
SCRAPINGBEE_API_KEY=

# ── LLM (reply classification + message personalization) ─────────────────────
# Anthropic — get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
# Cheap/fast model for reply classification.
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# ── Queue backend ─────────────────────────────────────────────────────────────
# "local" (CSV under ./data, zero setup) or "sheets" (Google Sheets).
STORE_BACKEND=local

# Google Sheets (only needed when STORE_BACKEND=sheets) ───────────────────────
# Service-account JSON path + the target sheet ID (the long id in the sheet URL).
GOOGLE_SHEETS_CREDENTIALS=./credentials/gsheets.json
GOOGLE_SHEET_ID=

# ── Outreach guardrails ──────────────────────────────────────────────────────
# Score at/below this goes to the outreach queue (lower = worse photos).
OUTREACH_SCORE_THRESHOLD=0.5
# Max first-messages per day from this Apple ID.
DAILY_SEND_CAP=20
# Random gap (seconds) between sends, to look human and avoid rate limits.
SEND_MIN_GAP_SECONDS=60
SEND_MAX_GAP_SECONDS=180
# Only send during these local hours (24h). Outside this window outreach pauses.
SEND_HOUR_START=10
SEND_HOUR_END=18
# Your business name, used in message templates.
BUSINESS_NAME=SA Real Estate Media
SENDER_FIRST_NAME=Joel
