# Copy this to .env and fill in your keys.

# ── Scraping ────────────────────────────────────────────────────────────────
# ScrapingBee — optional fallback. The default scraper uses a real Chrome
# browser (Playwright) and needs no key. Sign up at https://www.scrapingbee.com
SCRAPINGBEE_API_KEY=
# Tavily — optional. Only used by the legacy `--source tavily` scraper now that
# the default Redfin scan runs through Scrapling (a stealth browser, no API key).
# Sign up at https://app.tavily.com
TAVILY_API_KEY=
# Default listing scan source: redfin (Scrapling stealth browser, no key needed)
# or unlockmls (Austin IDX only).
SCAN_SOURCE=redfin
# HasData — live Zillow listing scrape via their proxy/anti-bot infra. Works
# from a datacenter (Render), unlike running our own Playwright against Zillow.
# 1,000 free credits, no card: https://hasdata.com
# Use: python run.py scrape --source hasdata --city Austin --state TX
HASDATA_API_KEY=

# ── Queue backend ─────────────────────────────────────────────────────────────
# "local" (CSV under ./data, zero setup) or "sheets" (Google Sheets).
STORE_BACKEND=local

# Google Sheets (only needed when STORE_BACKEND=sheets) ───────────────────────
# Service-account JSON path + the target sheet ID (the long id in the sheet URL).
GOOGLE_SHEETS_CREDENTIALS=./credentials/gsheets.json
GOOGLE_SHEET_ID=

# ── Outreach guardrails ──────────────────────────────────────────────────────
# Score at/below this goes to the outreach queue (lower = worse photos).
# 0.70 matches the photo-craft scorer (pro ~0.88, amateur ~0.53-0.60).
OUTREACH_SCORE_THRESHOLD=0.70
# Skip listings that already include aerial/drone photography.
EXCLUDE_DRONE_LISTINGS=true
AERIAL_THRESHOLD=0.6
EXCLUDE_VIRTUAL_TOUR_LISTINGS=true
# Max first-messages per day from this Apple ID. Start low (3-5) and ramp only
# if delivery stays clean — cold blasting is what gets an account throttled.
DAILY_SEND_CAP=5
# Random gap (seconds) between sends, to look human and avoid rate limits.
# Default cadence: one text every 1m30s (90s) ± 15s.
SEND_MIN_GAP_SECONDS=75
SEND_MAX_GAP_SECONDS=105
# Only send during these local hours (24h). Outside this window outreach pauses.
SEND_HOUR_START=10
SEND_HOUR_END=18
# Seconds to wait for an iMessage delivery receipt (read back from chat.db)
# before marking a number undeliverable and skipping it. Numbers that aren't on
# iMessage will fail here and be skipped (no SMS fallback). Requires Full Disk
# Access for the terminal/app running this.
DELIVERY_CHECK_SECONDS=15
# ── Message content (used by the templates) ─────────────────────────────────
BUSINESS_NAME=SA Real Estate Media
SENDER_FIRST_NAME=Joel
SERVICE_AREA=San Antonio/Austin area
CONTACT_PHONE=(210) 741-1810
SPECIAL_OFFER=$99 for 25 photos + 5 drone photos
# Your portfolio URL (leave blank to omit the website mention).
WEBSITE=
# Append a short "Reply STOP" opt-out line to each message (recommended).
INCLUDE_OPT_OUT=true

# ── Instagram outreach ───────────────────────────────────────────────────────
# Max DMs per day (keep lower than iMessage — Instagram is stricter).
IG_DAILY_DM_CAP=10
IG_MIN_GAP_SECONDS=120
IG_MAX_GAP_SECONDS=300
# assisted = open profile + copy message to clipboard (you paste & send)
# automated = Playwright clicks Message and sends (higher ban risk)
IG_SEND_MODE=assisted
IG_BROWSER_PROFILE=./browser_profile/instagram
IG_DISCOVERY_HASHTAGS=sanantoniorealtor,satxrealtor,austinrealtor,atxrealtor
IG_EXCLUDE_KEYWORDS=lender,mortgage,loan officer,photographer,staging,stager,title company,insurance
IG_REALTOR_KEYWORDS=realtor,real estate,realty,broker,agent,listing,properties,homes
# Skip realtors you already follow (or have a pending follow request to).
IG_SKIP_ALREADY_FOLLOWING=true
# CLIP text ranking thresholds for IG discovery (0–1 softmax scores).
IG_REALTOR_SCORE_THRESHOLD=0.55
IG_CITY_SCORE_THRESHOLD=0.45
IG_EXCLUDE_SCORE_THRESHOLD=0.60
# Cosine similarity above this vs DNC/sent/following → skip as semantic duplicate.
IG_SEMANTIC_DUP_THRESHOLD=0.92
# Google site:instagram.com fallback retrieval (Playwright, free).
IG_GOOGLE_SEARCH_ENABLED=true

# ── OpenAI — AI discovery agent (default for IG discover) ───────────────────────
# Required for ig-discover / web Discover button. Get key: platform.openai.com/api-keys
OPENAI_API_KEY=
# agent = GPT tool-calling agent (default) | borderline = CLIP + GPT gray zone | clip_only = CLIP only
IG_LLM_ENABLED=true
IG_LLM_MODE=agent
IG_LLM_MODEL=gpt-4o-mini
IG_LLM_EXPAND_QUERIES=true
